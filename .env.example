# API Keys
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Application Settings
APP_NAME=Festiva Planner AI
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=sqlite:///./festiva.db

# Model Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gpt-3.5-turbo
TEMPERATURE=0.7
MAX_TOKENS=1000

# RAG Settings
VECTOR_STORE_PATH=./data/vector_store
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
